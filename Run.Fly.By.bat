batch<br>@echo off<br>SET "SIRIL_PY=%LocalAppData%\siril\venv\Scripts\python.exe"<br><br>IF EXIST "%SIRIL_PY%" (<br>    echo [LOG] Siril Python environment detected. Launching...<br>    "%SIRIL_PY%" -m pip install -r "%~dp0requirements.txt" --quiet<br>    "%SIRIL_PY%" "%~dp0src\main.py"<br>) ELSE (<br>    echo [LOG] Siril environment not detected. Using system Python...<br>    python -m pip install -r "%~dp0requirements.txt" --quiet<br>    python "%~dp0src\main.py"<br>)<br>pause<br>
